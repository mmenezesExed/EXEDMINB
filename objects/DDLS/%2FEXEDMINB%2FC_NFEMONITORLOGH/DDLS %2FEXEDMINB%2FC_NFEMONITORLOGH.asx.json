    "SOURCE":"@AccessControl.authorizationCheck: #NOT_REQUIRED\r\n@EndUserText.label: 'Composition Monitor Header'\r\n//@Metadata.ignorePropagatedAnnotations: true\r\n@Metadata.allowExtensions: true\r\ndefine root view entity /EXEDMINB/C_NFEMONITORLOGH\r\n  provider contract transactional_query\r\n  as projection on /EXEDMINB/I_NFEMONITORLOGH\r\n{\r\n  key     ChaveNFe,\r\n          Status,\r\n          StatusCriticality,\r\n          @ObjectModel.text.element: [ 'StatusNFeDescricao' ]\r\n          StatusNFe,\r\n          @Consumption.valueHelpDefinition: [{ entity: { name: 'I_CompanyCodeVH', element: 'CompanyCode'  }}]\r\n          @ObjectModel.text.element: [ 'CompanyCodeName' ]\r\n          Empresa,\r\n          @Consumption.valueHelpDefinition: [{ entity: { name: 'I_BR_BusinessPlace', element: 'Branch'  }}]\r\n          @ObjectModel.text.element: [ 'BusinessPlaceName' ]\r\n          LocalDeNegocio,\r\n          ProcessoSAP,\r\n          @Consumption.valueHelpDefinition: [{ entity: { name: '/EXEDMINB/C_ATIVIDADES', element: 'atividade'  }}]\r\n          @ObjectModel.text.element: [ 'AtividadeDescricao' ]\r\n          Atividade,\r\n          NumeroNFe,\r\n          Serie,\r\n          DataEmissao,\r\n          EntradaMercadoria,\r\n          Fatura,\r\n          Delivery,\r\n          DANFE,\r\n          @Consumption.valueHelpDefinition: [{ entity: { name: 'I_Supplier', element: 'TaxNumber1'  }}]\r\n          Emitente,\r\n          NomeEmitente,\r\n          @Consumption.valueHelpDefinition: [{ entity: { name: 'I_Supplier', element: 'TaxNumber1'  }}]\r\n          Destinatario,\r\n          NomeDestinatario,\r\n          ValorTotalNFe,\r\n          ValorTotalICMS,\r\n          ValorTotalIPI,\r\n          ValorTotalICMSST,\r\n          ValorFrete,\r\n          ValorSeguro,\r\n          ValorOutrasDesp,\r\n          AtividadeDescricao,\r\n          StatusNFeDescricao,\r\n          CompanyCodeName,\r\n          BusinessPlaceName,\r\n\r\n\r\n\r\n          /* Associations */\r\n          _Files     : redirected to /EXEDMINB/C_NFEFILES,\r\n          _Delivery  : redirected to composition child /EXEDMINB/C_NFEMINBDELIVERY,\r\n          _Item      : redirected to composition child /EXEDMINB/C_NFEMONITORLOGI,\r\n          _Historico : redirected to /EXEDMINB/C_HISTORICO\r\n}\r\n/*+[internal] {\n\"BASEINFO\":\n{\n\"FROM\":\n[\n\"/EXEDMINB/I_NFEMONITORLOGH\"\n],\n\"ASSOCIATED\":\n[\n\"/EXEDMINB/C_HISTORICO\",\n\"/EXEDMINB/C_NFEFILES\",\n\"/EXEDMINB/C_NFEMINBDELIVERY\",\n\"/EXEDMINB/C_NFEMONITORLOGI\",\n\"/EXEDMINB/I_HISTORICO\",\n\"/EXEDMINB/I_NFEFILES\",\n\"/EXEDMINB/I_NFEMINBDELIVERY\",\n\"/EXEDMINB/I_NFEMONITORLOGI\"\n],\n\"BASE\":\n[\n\"/EXEDMINB/I_NFEMONITORLOGH\"\n],\n\"ANNO_REF\":\n[],\n\"SCALAR_FUNCTION\":\n[],\n\"VERSION\":0,\n\"ANNOREF_EVALUATION_ERROR\":\"\"\n}\n}*/",
